# Copy this file to .env.local and adjust values for your environment.
# Vite only exposes variables prefixed with VITE_ to the browser bundle.

# WebSocket URL of the backend.
# Local development default (set automatically if omitted):
VITE_WS_URL=ws://localhost:8000/ws/stream

# Cloud / production example (replace with your actual backend URL):
# VITE_WS_URL=wss://your-backend.railway.app/ws/stream
